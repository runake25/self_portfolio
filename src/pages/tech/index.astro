---
import CollectionCard from "@/components/content/CollectionCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { entryHref } from "@/utilities/content";
import { getCollection } from "astro:content";

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const posts = (await getCollection("tech", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf(),
);
---

<BaseLayout title="Journal | Your Name" description="Journal entries and notes.">
  <section class="space-y-8">
    <p class="section-label">topic</p>
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl" style="color:var(--text-primary)">Journal</h1>
    <p class="max-w-3xl text-sm" style="color:var(--text-secondary)">
      Use this page for writing logs, updates, and process notes.
    </p>

    {
      posts.length === 0 ? (
        <p class="text-zinc-400">No entries yet. Add your first note in src/content/tech.</p>
      ) : (
        <div class="grid gap-4">
          {posts.map((post) => (
            <CollectionCard
              href={entryHref("tech", post.id)}
              title={post.data.title}
              description={post.data.description}
              meta={`subtopic: ${dateFormatter.format(post.data.publishedDate)}`}
              tags={post.data.tags}
            />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
