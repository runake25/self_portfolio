---
import MusicAlbumCard from "@/components/content/MusicAlbumCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const entries = (await getCollection("music")).sort(
  (a, b) => b.data.listenedDate.valueOf() - a.data.listenedDate.valueOf(),
);
---

<BaseLayout title="Music | Brian" description="Music I love.">
  <section class="space-y-8">
    <p class="section-label">Explore · Music</p>
    <div class="flex items-end justify-between gap-3 flex-wrap">
      <div>
        <h1 class="text-3xl font-bold tracking-tight" style="color:var(--text-primary)">Best Albums</h1>
        <p class="mt-1 text-sm" style="color:var(--text-secondary)">
          Albums and artists that stuck with me.
          {entries.length > 0 && <span style="color:var(--text-faint)">— {entries.length} entries</span>}
        </p>
      </div>
      {entries.length > 1 && (
        <button id="music-pick-btn" class="execute-button secondary pick-one-btn" type="button">
          ◎ pick one
        </button>
      )}
    </div>

    {entries.length === 0 ? (
      <p style="color:var(--text-faint)">No entries yet. Add your first album in src/content/music.</p>
    ) : (
      <div id="music-grid" class="music-grid">
        {entries.map((entry, i) => (
          <MusicAlbumCard
            musicId={entry.id}
            title={entry.data.title}
            artist={entry.data.artist}
            coverArt={entry.data.coverArt}
            releaseYear={entry.data.releaseYear}
            genre={entry.data.genre}
            description={entry.data.description}
            priority={true}
          />
        ))}
      </div>
    )}
  </section>

  <!-- Shared backdrop -->
  <div id="music-backdrop" class="music-backdrop" aria-hidden="true"></div>

  <!-- One modal per album (hidden, populated at build time) -->
  {entries.map((entry) => (
    <div
      id={`music-modal-${entry.id}`}
      class="music-modal"
      role="dialog"
      aria-modal="true"
      aria-label={entry.data.title}
      hidden
    >
      <button class="music-modal-close" aria-label="Close" type="button">✕</button>
      <div class="music-modal-inner">
        <div class="music-modal-art-wrap">
          {entry.data.coverArt ? (
            <Image
              src={entry.data.coverArt}
              alt={`${entry.data.title}${entry.data.artist ? ` by ${entry.data.artist}` : ""} album cover`}
              width={500}
              height={500}
              format="avif"
              loading="lazy"
              decoding="async"
              class="music-modal-art"
            />
          ) : (
            <div class="music-modal-art-placeholder">♪</div>
          )}
        </div>
        <div class="music-modal-info">
          <h2 class="music-modal-title">{entry.data.title}</h2>
          {entry.data.artist && (
            <p class="music-modal-artist">{entry.data.artist}</p>
          )}
          <div class="music-modal-year-genre">
            {entry.data.releaseYear && <span>{entry.data.releaseYear}</span>}
            {entry.data.genre && entry.data.genre.length > 0 && (
              <span class="music-modal-genres">
                {entry.data.genre.map((g) => <span class="music-genre-tag">{g}</span>)}
              </span>
            )}
          </div>
          {entry.data.description && (
            <p class="music-modal-description">{entry.data.description}</p>
          )}
          {entry.data.keyTracks && entry.data.keyTracks.length > 0 && (
            <div class="music-modal-tracks">
              <p class="music-modal-tracks-label">key tracks</p>
              <ul>
                {entry.data.keyTracks.map((track) => <li>{track}</li>)}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  ))}
</BaseLayout>

<script is:inline>
  (function () {
    // ─── Pick One ────────────────────────────────────────────────
    var pickBtn = document.getElementById("music-pick-btn");
    var grid = document.getElementById("music-grid");
    if (pickBtn && grid) {
      var pickCards = Array.from(grid.querySelectorAll("button.music-album-card"));
      if (pickCards.length >= 2) {
        var running = false;
        function clearPicks() {
          pickCards.forEach(function (c) {
            c.classList.remove("pick-scanning", "pick-highlight");
          });
        }
        window.addEventListener("pageshow", function (e) {
          if (e.persisted) {
            clearPicks();
            pickBtn.textContent = "◎ pick one";
            pickBtn.disabled = false;
            running = false;
          }
        });
        pickBtn.addEventListener("click", function () {
          if (running) return;
          running = true;
          pickBtn.disabled = true;
          pickBtn.textContent = "scanning...";
          clearPicks();
          var total = pickCards.length;
          var targetIndex = Math.floor(Math.random() * total);
          var totalSteps = 4 * total + targetIndex + 1;
          var step = 0;
          var prevIdx = -1;
          function scan() {
            if (prevIdx >= 0) pickCards[prevIdx].classList.remove("pick-scanning");
            var idx = step % total;
            pickCards[idx].classList.add("pick-scanning");
            prevIdx = idx;
            step++;
            if (step < totalSteps) {
              var progress = step / totalSteps;
              // starts fast (~35ms), decelerates sharply at end
              var delay = 35 + Math.pow(progress, 2.8) * 480;
              setTimeout(scan, delay);
            } else {
              pickCards[prevIdx].classList.remove("pick-scanning");
              var winner = pickCards[targetIndex];
              winner.classList.add("pick-highlight");
              winner.scrollIntoView({ behavior: "smooth", block: "nearest" });
              pickBtn.textContent = "◎ pick one";
              pickBtn.disabled = false;
              running = false;
            }
          }
          scan();
        });

        // Clear pick highlight when clicking anywhere outside the winner
        document.addEventListener("click", function (e) {
          var highlighted = grid.querySelector(".pick-highlight");
          if (!highlighted) return;
          if (!highlighted.contains(e.target)) {
            highlighted.classList.remove("pick-highlight");
          }
        });
      }
    }

    // ─── Album modal ─────────────────────────────────────────────
    var backdrop = document.getElementById("music-backdrop");
    var activeModal = null;

    function openModal(id) {
      var modal = document.getElementById("music-modal-" + id);
      if (!modal || !backdrop) return;
      activeModal = modal;
      modal.removeAttribute("hidden");
      backdrop.removeAttribute("hidden");
      document.body.style.overflow = "hidden";
      // Double rAF ensures hidden→visible transition fires
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          backdrop.classList.add("is-active");
          modal.classList.add("is-active");
        });
      });
      var closeBtn = modal.querySelector(".music-modal-close");
      if (closeBtn) closeBtn.focus();
    }

    function closeModal() {
      if (!activeModal || !backdrop) return;
      var toHide = activeModal;
      activeModal = null;
      toHide.classList.remove("is-active");
      backdrop.classList.remove("is-active");
      document.body.style.overflow = "";
      setTimeout(function () {
        toHide.setAttribute("hidden", "");
        backdrop.setAttribute("hidden", "");
      }, 280);
    }

    document.querySelectorAll("button.music-album-card[data-music-id]").forEach(function (card) {
      card.addEventListener("click", function () {
        openModal(card.dataset.musicId);
      });
    });

    if (backdrop) backdrop.addEventListener("click", closeModal);

    document.querySelectorAll(".music-modal-close").forEach(function (btn) {
      btn.addEventListener("click", closeModal);
    });

    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && activeModal) closeModal();
    });
  })();
</script>


