---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { entryHref, entrySlugFromId } from "@/utilities/content";
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const entries = (await getCollection("music")).sort(
    (a, b) => b.data.entryDate.valueOf() - a.data.entryDate.valueOf(),
  );

  return entries.map((entry, index) => ({
    params: { slug: entrySlugFromId(entry.id) },
    props: {
      entry,
      prevEntry: index + 1 < entries.length ? entries[index + 1] : null,
      nextEntry: index > 0 ? entries[index - 1] : null,
    },
  }));
}

const { entry, prevEntry, nextEntry } = Astro.props;
const { Content } = await render(entry);

const prevPage = prevEntry
  ? { label: "Older entry", title: prevEntry.data.title, url: entryHref("music", prevEntry.id) }
  : null;

const nextPage = nextEntry
  ? { label: "Newer entry", title: nextEntry.data.title, url: entryHref("music", nextEntry.id) }
  : null;
---

<BaseLayout
  title={`${entry.data.title} | Music`}
  description={entry.data.description}
  prevPage={prevPage}
  nextPage={nextPage}
  noSketch={true}
>
  <article class="article-page">
    <a href="/music" class="article-back">← Back to Music</a>

    <!-- Hero: art + core metadata -->
    <div class="music-entry-hero">
      {entry.data.coverArt ? (
        <div class="music-entry-art-wrap">
          <Image
            src={entry.data.coverArt}
            alt={`${entry.data.title}${entry.data.artist ? ` by ${entry.data.artist}` : ""} album cover`}
            width={500}
            height={500}
            format="avif"
            loading="eager"
            decoding="async"
            class="music-entry-art-img"
          />
        </div>
      ) : (
        <div class="music-entry-art-wrap music-entry-art-placeholder">♪</div>
      )}

      <div class="music-entry-meta">
        <p class="section-label">Music</p>
        <h1 class="music-entry-title">{entry.data.title}</h1>
        {entry.data.artist && <p class="music-entry-artist">{entry.data.artist}</p>}
        <div class="music-entry-tags">
          {entry.data.releaseYear && (
            <span class="music-entry-year">{entry.data.releaseYear}</span>
          )}
          {entry.data.genre?.map((g) => (
            <span class="music-genre-tag">{g}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- Description -->
    {entry.data.description && (
      <p class="music-entry-desc">{entry.data.description}</p>
    )}

    <!-- Key tracks -->
    {entry.data.keyTracks && entry.data.keyTracks.length > 0 && (
      <div class="music-modal-tracks music-entry-tracks">
        <p class="music-modal-tracks-label">Key Tracks</p>
        <ul>
          {entry.data.keyTracks.map((track) => <li>{track}</li>)}
        </ul>
      </div>
    )}

    <!-- Prose / MDX content -->
    <div class="prose max-w-none music-entry-prose">
      <Content />
    </div>
  </article>
</BaseLayout>
