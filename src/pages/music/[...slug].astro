---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { entryHref, entrySlugFromId } from "@/utilities/content";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const entries = (await getCollection("music")).sort(
    (a, b) => b.data.entryDate.valueOf() - a.data.entryDate.valueOf(),
  );

  return entries.map((entry, index) => ({
    params: { slug: entrySlugFromId(entry.id) },
    props: {
      entry,
      prevEntry: index + 1 < entries.length ? entries[index + 1] : null,
      nextEntry: index > 0 ? entries[index - 1] : null,
    },
  }));
}

const { entry, prevEntry, nextEntry } = Astro.props;
const { Content } = await render(entry);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const prevPage = prevEntry
  ? { label: "Older entry", title: prevEntry.data.title, url: entryHref("music", prevEntry.id) }
  : null;

const nextPage = nextEntry
  ? { label: "Newer entry", title: nextEntry.data.title, url: entryHref("music", nextEntry.id) }
  : null;
---

<BaseLayout
  title={`${entry.data.title} | Music`}
  description={entry.data.description}
  prevPage={prevPage}
  nextPage={nextPage}
  noSketch={true}
>
  <article class="article-page">
    <a href="/music" class="article-back">← Back</a>
    <header class="article-header">
      <p class="section-label">Music</p>
      <h1>{entry.data.title}</h1>
      <div class="article-meta">
        {entry.data.artist && <span>{entry.data.artist}</span>}
        {entry.data.artist && <span>•</span>}
        <span>Listened {dateFormatter.format(entry.data.entryDate)}</span>
      </div>
      {entry.data.description && <p class="lead">{entry.data.description}</p>}
    </header>

    <div class="prose max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
