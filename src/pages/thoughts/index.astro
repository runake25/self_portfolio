---
import CollectionCard from "@/components/content/CollectionCard.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { entryHref } from "@/utilities/content";
import { getCollection } from "astro:content";

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const posts = (await getCollection("thoughts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf(),
);
---

<BaseLayout title="Thoughts | Brian" description="Reflections and writing.">
  <section class="space-y-8">
    <p class="section-label">Brian</p>
    <h1 class="text-3xl font-bold tracking-tight sm:text-4xl" style="color:var(--text-primary)">Thoughts</h1>
    <p class="max-w-3xl text-sm" style="color:var(--text-secondary)">
      Reflections, opinions, and things I think about.
    </p>

    {
      posts.length === 0 ? (
        <p style="color:var(--text-faint)">No entries yet. Thinking hard ...</p>
      ) : (
        <div class="grid gap-4">
          {posts.map((post) => (
            <CollectionCard
              href={entryHref("thoughts", post.id)}
              title={post.data.title}
              description={post.data.description}
              meta={dateFormatter.format(post.data.publishedDate)}
              tags={post.data.tags}
            />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
