---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { entryHref, entrySlugFromId } from "@/utilities/content";
import { tagAccentEntry } from "@/utilities/tagColors";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = (await getCollection("thoughts", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.publishedDate.valueOf() - a.data.publishedDate.valueOf(),
  );

  return posts.map((entry, index) => ({
    params: { slug: entrySlugFromId(entry.id) },
    props: {
      entry,
      prevEntry: index + 1 < posts.length ? posts[index + 1] : null,
      nextEntry: index > 0 ? posts[index - 1] : null,
    },
  }));
}

const { entry, prevEntry, nextEntry } = Astro.props;
const { Content } = await render(entry);

const topicAccent = tagAccentEntry(entry.data.tags);
const readTime = Math.max(1, Math.ceil((entry.body?.split(/\s+/).filter(Boolean).length ?? 0) / 200));

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const prevPage = prevEntry
  ? { label: "Older thought", title: prevEntry.data.title, url: entryHref("thoughts", prevEntry.id) }
  : null;

const nextPage = nextEntry
  ? { label: "Newer thought", title: nextEntry.data.title, url: entryHref("thoughts", nextEntry.id) }
  : null;
---

<BaseLayout
  title={`${entry.data.title} | Thoughts`}
  description={entry.data.description}
  prevPage={prevPage}
  nextPage={nextPage}
  noSketch={true}
>
  <article class="article-page">
    <a href="/thoughts" class="article-back">← Back</a>
    <header class="article-header">
      {topicAccent
        ? <p class="section-label" style={`color:${topicAccent.color}`}>{topicAccent.tag}</p>
        : <p class="section-label">Thoughts</p>
      }
      <h1>{entry.data.title}</h1>
      <div class="article-meta">
        {entry.data.tags && entry.data.tags.length > 0 && (
          <>
            {entry.data.tags.map((tag) => <span class="tag-chip">{tag}</span>)}
            <span style="color:var(--text-faint)">|</span>
          </>
        )}
        <span>{dateFormatter.format(entry.data.publishedDate)}</span>
        <span style="color:var(--text-faint)">|</span>
        <span>{readTime} min read</span>
      </div>
      {entry.data.description && <p class="lead">{entry.data.description}</p>}
    </header>

    <div class="prose max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
