---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { entryHref, entrySlugFromId } from "@/utilities/content";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const entries = (await getCollection("places")).sort(
    (a, b) => b.data.visitedDate.valueOf() - a.data.visitedDate.valueOf(),
  );

  return entries.map((entry, index) => ({
    params: { slug: entrySlugFromId(entry.id) },
    props: {
      entry,
      prevEntry: index + 1 < entries.length ? entries[index + 1] : null,
      nextEntry: index > 0 ? entries[index - 1] : null,
    },
  }));
}

const { entry, prevEntry, nextEntry } = Astro.props;
const { Content } = await render(entry);

const dateFormatter = new Intl.DateTimeFormat("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const prevPage = prevEntry
  ? { label: "Older entry", title: prevEntry.data.title, url: entryHref("places", prevEntry.id) }
  : null;

const nextPage = nextEntry
  ? { label: "Newer entry", title: nextEntry.data.title, url: entryHref("places", nextEntry.id) }
  : null;
---

<BaseLayout
  title={`${entry.data.title} | Places`}
  description={entry.data.description}
  prevPage={prevPage}
  nextPage={nextPage}
  noSketch={true}
>
  <article class="article-page">
    <a href="/places" class="article-back">← Back</a>
    <header class="article-header">
      <p class="section-label">Places</p>
      <h1>{entry.data.title}</h1>
      <div class="article-meta">
        {entry.data.location && <span>{entry.data.location}</span>}
        {entry.data.location && <span>•</span>}
        <span>Visited {dateFormatter.format(entry.data.visitedDate)}</span>
        {typeof entry.data.rating === "number" && (
          <>
            <span>•</span>
            <span>Rating {entry.data.rating}/5</span>
          </>
        )}
      </div>
      {entry.data.description && <p class="lead">{entry.data.description}</p>}
    </header>

    <div class="prose max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
